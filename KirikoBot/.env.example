# ====================
# KirikoBot 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ====================

# QQ机器人账号
ROBOT_QQ="你的QQ号"

# OneBot API 地址
ONEBOT_API="http://llbot:3000"

# OneBot 连接令牌
ONEBOT_TOKEN="your_token_here"

# DeepSeek API 地址
DEEPSEEK_API="https://api.deepseek.com/chat/completions"

# DeepSeek API 密钥
DEEPSEEK_TOKEN="your_deepseek_api_key"

# 主聊天角色设定
MAIN_ROLE="你是聊天小助手Kiriko..."

# 群聊角色设定
GROUP_ROLE="你是聊天小助手Kiriko..."

# 私聊角色设定
PRIVATE_ROLE="你是聊天小助手Kiriko..."

# 塔罗牌解读角色设定
TAROT_ROLE="你是牌面解读助手Kiriko..."

# ── 图像识别 API（可选）──────────────────────
# 支持任何兼容 OpenAI 格式的视觉模型 API
# 如：硅基流动(SiliconFlow)、Qwen-VL、Together AI 等
# 不配置则使用上下文推断代替图像识别
# VISION_API_URL="https://api.siliconflow.cn/v1/chat/completions"
# VISION_API_KEY="your_vision_api_key"
# VISION_MODEL="Qwen/Qwen2-VL-7B-Instruct"
